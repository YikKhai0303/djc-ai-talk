---
---
<script src="https://code.iconify.design/iconify-icon/2.1.0/iconify-icon.min.js" is:inline></script>

<section class="bg-white py-16 lg:py-24 px-6 relative">
    <div class="absolute inset-0 pointer-events-none grid-corners" aria-hidden="true"></div>
    <div class="max-w-5xl mx-auto relative">

        <!-- Section Header -->
        <div class="text-center mb-12">
            <div class="inline-block border border-black text-sm font-bold tracking-widest px-4 py-1 mb-6 rounded">
                AI IN CUSTOMER COMMUNICATION
            </div>
            <h2 class="text-3xl lg:text-4xl font-bold leading-snug mb-4">
                Fast and Consistent Replies Matter Most
            </h2>
            <p class="text-base text-gray-600 max-w-2xl mx-auto">
                As customer expectations rise, businesses are under growing pressure to reply quickly, consistently, and at scale.
            </p>
        </div>

        <!-- Cards Grid -->
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">

            <!-- Card 1 -->
            <div class="rounded-xl overflow-hidden shadow-sm border border-gray-100">
                <!-- Pain Point -->
                <div class="bg-[#F7F7F7] px-6 pt-6 pb-5">
                    <div class="flex items-start gap-4">
                        <div class="shrink-0 mt-0.5">
                            <!-- Speech bubble icon -->
                            <svg class="w-5 h-5 text-gray-400" viewBox="0 0 20 20" fill="none">
                                <path d="M3 4a2 2 0 012-2h10a2 2 0 012 2v7a2 2 0 01-2 2H8l-4 3v-3H5a2 2 0 01-2-2V4z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
                                <path d="M6 7h8M6 10h5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
                            </svg>
                        </div>
                        <p class="text-sm font-semibold text-gray-700 leading-snug">
                            Are customers waiting too long for a reply?
                        </p>
                    </div>
                </div>
                <!-- AI Solution -->
                <div class="bg-white px-6 pt-4 pb-6">
                    <div class="flex items-center gap-4">
                        <div class="shrink-0">
                            <!-- Checkmark circle icon -->
                            <svg class="w-5 h-5" viewBox="0 0 20 20" fill="none">
                                <circle cx="10" cy="10" r="9" fill="black"/>
                                <path d="M7 10h6M10.5 7l3 3-3 3" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                            </svg>
                        </div>
                        <p class="text-sm text-gray-500 leading-relaxed">
                            AI can respond instantly to common inquiries, helping businesses reply faster and reduce missed opportunities.
                        </p>
                    </div>
                </div>
            </div>

            <!-- Card 2 -->
            <div class="rounded-xl overflow-hidden shadow-sm border border-gray-100">
                <div class="bg-[#F7F7F7] px-6 pt-6 pb-5">
                    <div class="flex items-start gap-4">
                        <div class="shrink-0 mt-0.5">
                            <svg class="w-5 h-5 text-gray-400" viewBox="0 0 20 20" fill="none">
                                <path d="M3 4a2 2 0 012-2h10a2 2 0 012 2v7a2 2 0 01-2 2H8l-4 3v-3H5a2 2 0 01-2-2V4z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
                                <path d="M6 7h8M6 10h5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
                            </svg>
                        </div>
                        <p class="text-sm font-semibold text-gray-700 leading-snug">
                            Is your team answering the same questions every day?
                        </p>
                    </div>
                </div>
                <div class="bg-white px-6 pt-4 pb-6">
                    <div class="flex items-center gap-4">
                        <div class="shrink-0">
                            <svg class="w-5 h-5" viewBox="0 0 20 20" fill="none">
                                <circle cx="10" cy="10" r="9" fill="black"/>
                                <path d="M7 10h6M10.5 7l3 3-3 3" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                            </svg>
                        </div>
                        <p class="text-sm text-gray-500 leading-relaxed">
                            AI can handle repetitive questions automatically, freeing your team to focus on higher-value conversations.
                        </p>
                    </div>
                </div>
            </div>

            <!-- Card 3 -->
            <div class="rounded-xl overflow-hidden shadow-sm border border-gray-100">
                <div class="bg-[#F7F7F7] px-6 pt-6 pb-5">
                    <div class="flex items-start gap-4">
                        <div class="shrink-0 mt-0.5">
                            <svg class="w-5 h-5 text-gray-400" viewBox="0 0 20 20" fill="none">
                                <path d="M3 4a2 2 0 012-2h10a2 2 0 012 2v7a2 2 0 01-2 2H8l-4 3v-3H5a2 2 0 01-2-2V4z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
                                <path d="M6 7h8M6 10h5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
                            </svg>
                        </div>
                        <p class="text-sm font-semibold text-gray-700 leading-snug">
                            Are leads coming in off-hours and going unanswered?
                        </p>
                    </div>
                </div>
                <div class="bg-white px-6 pt-4 pb-6">
                    <div class="flex items-center gap-4">
                        <div class="shrink-0">
                            <svg class="w-5 h-5" viewBox="0 0 20 20" fill="none">
                                <circle cx="10" cy="10" r="9" fill="black"/>
                                <path d="M7 10h6M10.5 7l3 3-3 3" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                            </svg>
                        </div>
                        <p class="text-sm text-gray-500 leading-relaxed">
                            AI can stay active beyond working hours, helping businesses engage inquiries even when the team is offline.
                        </p>
                    </div>
                </div>
            </div>

            <!-- Card 4 -->
            <div class="rounded-xl overflow-hidden shadow-sm border border-gray-100">
                <div class="bg-[#F7F7F7] px-6 pt-6 pb-5">
                    <div class="flex items-start gap-4">
                        <div class="shrink-0 mt-0.5">
                            <svg class="w-5 h-5 text-gray-400" viewBox="0 0 20 20" fill="none">
                                <path d="M3 4a2 2 0 012-2h10a2 2 0 012 2v7a2 2 0 01-2 2H8l-4 3v-3H5a2 2 0 01-2-2V4z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
                                <path d="M6 7h8M6 10h5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
                            </svg>
                        </div>
                        <p class="text-sm font-semibold text-gray-700 leading-snug">
                            Are replies inconsistent across different staff or channels?
                        </p>
                    </div>
                </div>
                <div class="bg-white px-6 pt-4 pb-6">
                    <div class="flex items-center gap-4">
                        <div class="shrink-0">
                            <svg class="w-5 h-5" viewBox="0 0 20 20" fill="none">
                                <circle cx="10" cy="10" r="9" fill="black"/>
                                <path d="M7 10h6M10.5 7l3 3-3 3" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                            </svg>
                        </div>
                        <p class="text-sm text-gray-500 leading-relaxed">
                            AI can deliver more consistent responses based on approved business information, improving customer experience.
                        </p>
                    </div>
                </div>
            </div>

        </div>

        <!-- Supported Platforms -->
        <div class="mt-14">
            <p class="text-base text-gray-600 text-center mb-6">
                Connects to wherever your customers message you
            </p>
            <div class="grid grid-cols-4 sm:grid-cols-8 gap-x-4 gap-y-6 justify-items-center">
                <div class="flex flex-col items-center gap-2">
                    <div class="platform-box">
                        <iconify-icon icon="logos:whatsapp-icon" style="font-size:36px"></iconify-icon>
                    </div>
                    <span class="text-xs font-medium text-gray-600 whitespace-nowrap">WhatsApp</span>
                </div>
                <div class="flex flex-col items-center gap-2">
                    <div class="platform-box relative">
                        <iconify-icon icon="logos:whatsapp-icon" style="font-size:36px"></iconify-icon>
                        <span class="absolute bottom-1 right-1 text-green-600 text-lg font-black leading-none">+</span>
                    </div>
                    <span class="text-xs font-medium text-gray-600 whitespace-nowrap">WABA</span>
                </div>
                <div class="flex flex-col items-center gap-2">
                    <div class="platform-box">
                        <iconify-icon icon="mdi:facebook" style="font-size:36px; color:#1877F2"></iconify-icon>
                    </div>
                    <span class="text-xs font-medium text-gray-600 whitespace-nowrap">Messenger</span>
                </div>
                <div class="flex flex-col items-center gap-2">
                    <div class="platform-box">
                        <iconify-icon icon="mdi:instagram" style="font-size:36px; color:#E1306C"></iconify-icon>
                    </div>
                    <span class="text-xs font-medium text-gray-600 whitespace-nowrap">Instagram</span>
                </div>
                <div class="flex flex-col items-center gap-2">
                    <div class="platform-box">
                        <iconify-icon icon="logos:telegram" style="font-size:36px"></iconify-icon>
                    </div>
                    <span class="text-xs font-medium text-gray-600 whitespace-nowrap">Telegram</span>
                </div>
                <div class="flex flex-col items-center gap-2">
                    <div class="platform-box">
                        <iconify-icon icon="simple-icons:zalo" style="font-size:36px; color:#0068FF"></iconify-icon>
                    </div>
                    <span class="text-xs font-medium text-gray-600 whitespace-nowrap">Zalo</span>
                </div>
                <div class="flex flex-col items-center gap-2">
                    <div class="platform-box">
                        <iconify-icon icon="simple-icons:line" style="font-size:36px; color:#06C755"></iconify-icon>
                    </div>
                    <span class="text-xs font-medium text-gray-600 whitespace-nowrap">LINE</span>
                </div>
                <div class="flex flex-col items-center gap-2">
                    <div class="platform-box">
                        <svg viewBox="0 0 36 36" width="36" height="36" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <!-- Bubble with tail on bottom-left -->
                            <path d="M4 6a4 4 0 014-4h20a4 4 0 014 4v16a4 4 0 01-4 4H10l-6 6V26V6z" fill="#4B5563"/>
                            <!-- Text lines -->
                            <line x1="10" y1="12" x2="26" y2="12" stroke="white" stroke-width="1.8" stroke-linecap="round"/>
                            <line x1="10" y1="18" x2="22" y2="18" stroke="white" stroke-width="1.8" stroke-linecap="round"/>
                        </svg>
                    </div>
                    <span class="text-xs font-medium text-gray-600 whitespace-nowrap">Chat Widget</span>
                </div>
            </div>
        </div>

        <!-- CTA -->
        <div class="text-center mt-12">
            <button
                id="open-signup-modal-chatbot"
                class="inline-block bg-black text-white text-base font-semibold px-8 py-4 rounded hover:bg-gray-800 transition-colors duration-200 cursor-pointer"
            >
                Reserve Your Free Seat
            </button>
            <p class="mt-2 text-sm text-gray-400">Limited seats available. Secure your spot early.</p>
        </div>

    </div>
</section>

<style>
    .platform-box {
        width: 52px;
        height: 52px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .grid-corners {
        background-image: repeating-linear-gradient(45deg, #e5e7eb 0, #e5e7eb 1px, transparent 0, transparent 50%);
        background-size: 20px 20px;
        -webkit-mask-image: radial-gradient(ellipse at 0% 0%, black 0%, transparent 45%),
                            radial-gradient(ellipse at 100% 100%, black 0%, transparent 45%);
        mask-image: radial-gradient(ellipse at 0% 0%, black 0%, transparent 45%),
                    radial-gradient(ellipse at 100% 100%, black 0%, transparent 45%);
        -webkit-mask-composite: source-over;
        mask-composite: add;
    }

</style>

<script>
    document.getElementById('open-signup-modal-chatbot')?.addEventListener('click', () => {
        const modal = document.getElementById('signup-modal');
        modal?.classList.remove('hidden');
        modal?.classList.add('flex');
        document.body.style.overflow = 'hidden';
    });
</script>
