---
---

<section class="bg-white text-black py-12 lg:py-16 px-6 relative">
    <div class="absolute inset-0 pointer-events-none grid-corners" aria-hidden="true"></div>
    <div class="max-w-5xl mx-auto grid grid-cols-1 lg:grid-cols-[3fr_2fr] gap-y-10 lg:gap-y-0 lg:gap-x-16 items-center relative">
        <!-- Left Column -->
        <div>
            <!-- Event Label -->
            <div class="inline-block border border-black text-xl font-bold tracking-widest px-4 py-1 mb-6 rounded">
                AI TALK
            </div>

            <!-- Headline -->
            <!-- Ori: AI Is Changing Business. Learn How to Use It. -->
            <h1 class="text-3xl lg:text-4xl font-bold leading-snug mb-6">
                What AI Can Do in 2026<br />
                That Most Business Owners<br />
                Still Don't Know
            </h1>
        
            <!-- Subheadline -->
            <p class="text-base text-gray-600 max-w-2xl mb-3">
                A free 2-hour talk showing how AI are transforming businesses in 2026.
            </p>

            <!-- Bullet Points -->
            <ul class="flex flex-col gap-2 text-sm text-gray-700 mb-8">
                <li class="flex items-center gap-3">
                    <svg class="w-5 h-5 shrink-0" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <circle cx="10" cy="10" r="9" stroke="black" stroke-width="1.5"/>
                        <path d="M6 10.5l3 3 5-5" stroke="black" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                    Powerful AI Tools in Action
                </li>
                <li class="flex items-center gap-3">
                    <svg class="w-5 h-5 shrink-0" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <circle cx="10" cy="10" r="9" stroke="black" stroke-width="1.5"/>
                        <path d="M6 10.5l3 3 5-5" stroke="black" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                    Chatbot Automation Demonstration
                </li>
                <li class="flex items-center gap-3">
                    <svg class="w-5 h-5 shrink-0" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <circle cx="10" cy="10" r="9" stroke="black" stroke-width="1.5"/>
                        <path d="M6 10.5l3 3 5-5" stroke="black" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                    Real Business Use Cases
                </li>
            </ul>

            <!-- Event Details -->
            <div class="flex flex-col gap-3 text-sm text-gray-700 mb-8">
                <div class="flex items-center gap-3">
                    <svg class="w-5 h-5 shrink-0" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <rect x="2" y="4" width="16" height="14" rx="2" stroke="black" stroke-width="1.8"/>
                        <path d="M2 8h16" stroke="black" stroke-width="1.8"/>
                        <path d="M6 2v4M14 2v4" stroke="black" stroke-width="1.8" stroke-linecap="round"/>
                    </svg>
                    <span class="w-12 font-semibold shrink-0">Date</span>
                    <span class="shrink-0">:</span>
                    <span>9<sup class="text-xs">th</sup> April 2026</span>
                </div>
                <div class="flex items-center gap-3">
                    <svg class="w-5 h-5 shrink-0" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <circle cx="10" cy="10" r="8" stroke="black" stroke-width="1.8"/>
                        <path d="M10 5v5l3 3" stroke="black" stroke-width="1.8" stroke-linecap="round"/>
                    </svg>
                    <span class="w-12 font-semibold shrink-0">Time</span>
                    <span class="shrink-0">:</span>
                    <span>8:00 PM &mdash; 10:00 PM</span>
                </div>
                <div class="flex items-center gap-3">
                    <svg class="w-5 h-5 shrink-0" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M10 2C7.24 2 5 4.24 5 7c0 4 5 11 5 11s5-7 5-11c0-2.76-2.24-5-5-5z" stroke="black" stroke-width="1.8" stroke-linejoin="round"/>
                        <circle cx="10" cy="7" r="2" stroke="black" stroke-width="1.5"/>
                    </svg>
                    <span class="w-12 font-semibold shrink-0">Venue</span>
                    <span class="shrink-0">:</span>
                    <span>Zoom Meeting</span>
                </div>
            </div>

            <!-- CTA Button -->
            <button
                id="open-signup-modal"
                class="inline-block bg-black text-white text-base font-semibold px-8 py-4 rounded hover:bg-gray-800 transition-colors duration-200 cursor-pointer"
            >
                Reserve Your Free Seat
            </button>

            <!-- Urgency -->
            <p class="mt-2 text-sm text-gray-400">
                Limited seats available. Secure your spot early.
            </p>

        </div>

        <!-- Right Column -->
        <div class="relative rounded-2xl overflow-hidden">
            <img
                src="/images/DaveChong.png"
                alt="Dave Chong"
                class="w-full h-[480px] lg:h-[520px] object-cover object-[center_20%] lg:object-[center_90%]"
            />
            <!-- Overlay Card -->
            <div class="absolute bottom-0 left-0 right-0 bg-[#252525] text-white px-6 py-3 text-center">
                <p class="text-xs uppercase tracking-widest text-gray-500 mb-0.5">Hosted By</p>
                <h3 class="text-base font-bold mb-2">Dave Chong</h3>
                <!-- <div class="flex items-stretch text-xs">
                    <div class="flex-1 flex flex-col items-center justify-center">
                        <span class="font-semibold block">CEO</span>
                        <span class="text-gray-400">DJC AI Sdn Bhd</span>
                    </div>
                    <div class="w-px bg-gray-600 mx-4"></div>
                    <div class="flex-1 flex flex-col items-center justify-center">
                        <span class="font-semibold block">Group Vice President</span>
                        <span class="text-gray-400">IQI Global</span>
                    </div>
                </div> -->
            </div>
        </div>
    </div>
</section>

<style>
    .grid-corners {
        background-image: linear-gradient(#e5e7eb 1px, transparent 1px), linear-gradient(90deg, #e5e7eb 1px, transparent 1px);
        background-size: 36px 36px;
        -webkit-mask-image: radial-gradient(ellipse at 0% 100%, black 0%, transparent 45%),
                            radial-gradient(ellipse at 100% 0%, black 0%, transparent 45%);
        mask-image: radial-gradient(ellipse at 0% 100%, black 0%, transparent 45%),
                    radial-gradient(ellipse at 100% 0%, black 0%, transparent 45%);
        -webkit-mask-composite: source-over;
        mask-composite: add;
    }
</style>

<!-- Signup Modal -->
<div id="signup-modal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/60 px-4">
    <div class="bg-white shadow-2xl w-full max-w-lg relative overflow-hidden">
        <!-- Close button -->
        <button id="close-signup-modal" class="absolute top-4 right-4 text-gray-400 hover:text-black transition-colors z-10 cursor-pointer">
            <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none">
                <path d="M18 6L6 18M6 6l12 12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
            </svg>
        </button>
        <!-- GHL Form -->
        <iframe
            src="https://link.djcsystem.com/widget/form/mhUO4ITUU4MfJbey2dHe"
            id="inline-mhUO4ITUU4MfJbey2dHe"
            data-layout="{'id':'INLINE'}"
            data-trigger-type="showAfter"
            data-trigger-value="10"
            data-activation-type="alwaysActivated"
            data-activation-value=""
            data-deactivation-type="neverDeactivate"
            data-deactivation-value=""
            data-form-name="26 Mar 2026 "
            data-height="undefined"
            data-layout-iframe-id="inline-mhUO4ITUU4MfJbey2dHe"
            data-form-id="mhUO4ITUU4MfJbey2dHe"
            title="26 Mar 2026 "
            style="width:100%;border:none;display:block;"
        ></iframe>
    </div>
</div>
<script src="https://link.djcsystem.com/js/form_embed.js"></script>

<script>
    const modal = document.getElementById('signup-modal');
    const openBtn = document.getElementById('open-signup-modal');
    const closeBtn = document.getElementById('close-signup-modal');

    openBtn?.addEventListener('click', () => {
        modal?.classList.remove('hidden');
        modal?.classList.add('flex');
        document.body.style.overflow = 'hidden';
    });

    function closeSignupModal() {
        modal?.classList.add('hidden');
        modal?.classList.remove('flex');
        document.body.style.overflow = '';
        if ((window as any).__vipPending) {
            const ref = sessionStorage.getItem('refCode');
            window.location.href = ref ? `/vip?ref=${encodeURIComponent(ref)}` : '/vip';
        }
    }

    closeBtn?.addEventListener('click', closeSignupModal);
    modal?.addEventListener('click', (e) => {
        if (e.target === modal) closeSignupModal();
    });

    // Referral code: read ?ref= from URL and inject into GHL signup iframe
    const refCode = new URLSearchParams(window.location.search).get('ref');
    if (refCode) {
        sessionStorage.setItem('refCode', refCode);
        const signupIframe = document.getElementById('inline-mhUO4ITUU4MfJbey2dHe') as HTMLIFrameElement | null;
        if (signupIframe) {
            const url = new URL(signupIframe.src);
            url.searchParams.set('ref', refCode);
            signupIframe.src = url.toString();
        }
    }
</script>
