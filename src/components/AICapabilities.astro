---
---

<section class="bg-[#EBEBEB] py-16 lg:py-24 px-6">
    <div class="max-w-5xl mx-auto">

        <!-- Section Header -->
        <div class="text-center mb-12">
            <div class="inline-block border border-black text-sm font-bold tracking-widest px-4 py-1 mb-6 rounded">
                WHAT AI CAN DO
            </div>
            <h2 class="text-3xl lg:text-4xl font-bold leading-snug mb-4">
                AI Is Already Transforming Business.<br />
                Are You Keeping Up?
            </h2>
            <p class="text-base text-gray-600 max-w-2xl mx-auto">
                A preview of the AI tools and real-world use cases we will be demonstrating live at the talk.
            </p>
        </div>

        <!-- Cards Grid -->
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">

            <!-- Card 1: Image Generation -->
            <div class="bg-white rounded-xl p-8 shadow-sm flex flex-col">
                <div class="mb-4">
                    <svg class="w-8 h-8" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <rect x="3" y="3" width="18" height="18" rx="2" stroke="black" stroke-width="1.5"/>
                        <circle cx="8.5" cy="8.5" r="1.5" stroke="black" stroke-width="1.5"/>
                        <path d="M3 16l5-5 4 4 3-3 6 6" stroke="black" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                </div>
                <h3 class="text-base font-bold mb-1">Image Generation</h3>
                <p class="text-sm text-gray-500">Turn simple ideas and everyday photos into professional visuals for ads, promotions, and social media.</p>
                <div class="flex-1 flex items-center">
                <div class="mt-5 w-full grid gap-x-3 gap-y-1.5" style="grid-template-columns: 1fr auto 1fr;">
                    <img src="/sample_images/SampleImageBefore.png" alt="Before" class="w-full rounded-lg" />
                    <div class="flex items-center text-gray-300">
                        <svg class="w-8 h-8" viewBox="0 0 40 24" fill="none">
                            <path d="M2 12h36M28 4l8 8-8 8" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                    </div>
                    <img src="/sample_images/SampleImageAfter.png" alt="AI Enhanced" class="w-full rounded-lg" />
                    <p class="text-center text-sm text-gray-500">Before</p>
                    <div></div>
                    <p class="text-center text-sm text-gray-500">AI Enhanced</p>
                </div>
                </div>
            </div>

            <!-- Card 2: Video Generation -->
            <div class="bg-white rounded-xl p-8 shadow-sm">
                <div class="mb-4">
                    <svg class="w-8 h-8" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <rect x="2" y="5" width="15" height="14" rx="2" stroke="black" stroke-width="1.5"/>
                        <path d="M17 9l5-3v12l-5-3V9z" stroke="black" stroke-width="1.5" stroke-linejoin="round"/>
                    </svg>
                </div>
                <h3 class="text-base font-bold mb-1">Video Generation</h3>
                <p class="text-sm text-gray-500">Bring static visuals to life with smooth promotional videos for ads and social media.</p>
                <div class="mt-5 relative overflow-hidden rounded-lg">
                    <video
                        src="/sample_images/SampleVideo.mp4"
                        autoplay
                        loop
                        muted
                        playsinline
                        class="w-full"
                    ></video>
                    <div class="absolute bottom-0 right-0 bg-black text-white text-sm px-3 py-1.5 rounded-tl-lg">
                        AI Generated Video
                    </div>
                </div>
            </div>

            <!-- Card 3: Music Generation -->
            <div class="bg-white rounded-xl p-8 shadow-sm">
                <div class="mb-4">
                    <svg class="w-8 h-8" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M9 18V6l12-2v12" stroke="black" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                        <circle cx="6" cy="18" r="3" stroke="black" stroke-width="1.5"/>
                        <circle cx="18" cy="16" r="3" stroke="black" stroke-width="1.5"/>
                    </svg>
                </div>
                <h3 class="text-base font-bold mb-1">Music Generation</h3>
                <p class="text-sm text-gray-500">Generate custom soundtracks that elevate mood, strengthen brand identity, and make marketing content more engaging.</p>
            </div>

            <!-- Card 4: Content Writing -->
            <div class="bg-white rounded-xl p-8 shadow-sm">
                <div class="mb-4">
                    <svg class="w-8 h-8" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M14 3H6a2 2 0 00-2 2v14a2 2 0 002 2h12a2 2 0 002-2V9l-6-6z" stroke="black" stroke-width="1.5" stroke-linejoin="round"/>
                        <path d="M14 3v6h6" stroke="black" stroke-width="1.5" stroke-linejoin="round"/>
                        <path d="M8 13h8M8 17h5" stroke="black" stroke-width="1.5" stroke-linecap="round"/>
                    </svg>
                </div>
                <h3 class="text-base font-bold mb-1">Content Writing</h3>
                <p class="text-sm text-gray-500">Turn rough ideas into polished copy for promotions, social media, and business communication.</p>
            </div>

            <!-- Card 5: Landing Page Builder -->
            <div class="bg-white rounded-xl p-8 shadow-sm">
                <div class="mb-4">
                    <svg class="w-8 h-8" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <rect x="2" y="3" width="20" height="18" rx="2" stroke="black" stroke-width="1.5"/>
                        <path d="M2 7h20" stroke="black" stroke-width="1.5"/>
                        <rect x="5" y="10" width="6" height="8" rx="1" stroke="black" stroke-width="1.5"/>
                        <path d="M14 10h5M14 13h5M14 16h3" stroke="black" stroke-width="1.5" stroke-linecap="round"/>
                    </svg>
                </div>
                <h3 class="text-base font-bold mb-1">Landing Page Builder</h3>
                <p class="text-sm text-gray-500">Build landing pages faster with AI-generated layout, copy, and structure designed to support campaigns and promotions.</p>
            </div>

            <!-- Card 6: YouTube → PDF -->
            <div class="bg-white rounded-xl p-8 shadow-sm">
                <div class="mb-4 flex items-center gap-2">
                    <!-- YouTube icon -->
                    <svg class="w-8 h-8" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <rect x="2" y="5" width="20" height="14" rx="3" stroke="black" stroke-width="1.5"/>
                        <path d="M10 9l5 3-5 3V9z" stroke="black" stroke-width="1.5" stroke-linejoin="round"/>
                    </svg>
                    <!-- Arrow -->
                    <svg class="w-4 h-4 text-gray-400" viewBox="0 0 16 16" fill="none">
                        <path d="M2 8h12M10 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                    <!-- PDF document icon -->
                    <svg class="w-8 h-8" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8l-6-6z" stroke="black" stroke-width="1.5" stroke-linejoin="round"/>
                        <path d="M14 2v6h6" stroke="black" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                        <path d="M8 13h8M8 17h5" stroke="black" stroke-width="1.5" stroke-linecap="round"/>
                    </svg>
                </div>
                <h3 class="text-base font-bold mb-1">YouTube &rarr; PDF</h3>
                <p class="text-sm text-gray-500">Transform YouTube videos into organized summaries and notes that make key ideas easier to learn, reference, and share.</p>
            </div>

        </div>
    </div>
</section>
