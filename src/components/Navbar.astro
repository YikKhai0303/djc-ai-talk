---
const { page } = Astro.props;
---

<nav class="fixed top-0 left-0 right-0 z-40 bg-[#EBEBEB] border-b border-gray-200">
    <div class="max-w-5xl mx-auto px-6 h-14 flex items-center justify-end gap-4">
        <div class="flex items-center gap-1 text-xs text-gray-600">
            <span id="nav-countdown-label" class="text-gray-400">Starts in</span>
            <span id="nav-countdown" class="font-semibold tabular-nums tracking-tight"></span>
        </div>
        {page !== 'vip' && (
            <a
                id="nav-cta-btn"
                href="#"
                class="bg-black text-white text-sm font-semibold px-5 py-2 rounded hover:bg-gray-800 transition-colors duration-200 cursor-pointer"
            >
                Sign Up
            </a>
        )}
    </div>
</nav>

<style is:global>
    @keyframes pulse-dot {
        0%, 100% { opacity: 1; }
        50% { opacity: 0.2; }
    }
    .countdown-live {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        color: #dc2626;
        font-weight: 700;
        animation: pulse-dot 1s ease-in-out infinite;
    }
    .live-dot {
        width: 7px;
        height: 7px;
        border-radius: 50%;
        background-color: #dc2626;
        display: inline-block;
        flex-shrink: 0;
    }
</style>

<script>
    const COURSE_LINK = '/course';

    const ctaBtn = document.getElementById('nav-cta-btn') as HTMLAnchorElement | null;
    const countdownEl = document.getElementById('nav-countdown');
    const labelEl = document.getElementById('nav-countdown-label');

    // Default: clicking opens the signup modal
    ctaBtn?.addEventListener('click', (e) => {
        if (ctaBtn.dataset.live !== 'true') {
            e.preventDefault();
            const modal = document.getElementById('signup-modal');
            modal?.classList.remove('hidden');
            modal?.classList.add('flex');
            document.body.style.overflow = 'hidden';
        }
    });

    // Countdown to 9 Apr 2026 8:00 PM MYT (UTC+8)
    const eventDate = new Date('2026-04-09T20:00:00+08:00');

    function goLive() {
        if (countdownEl) {
            countdownEl.innerHTML = '<span class="live-dot"></span> LIVE';
            countdownEl.classList.add('countdown-live');
        }
        if (labelEl) labelEl.textContent = '';
        if (ctaBtn) {
            ctaBtn.textContent = 'Browse Course';
            ctaBtn.href = COURSE_LINK;
            ctaBtn.dataset.live = 'true';
        }
    }

    function updateCountdown() {
        const diff = eventDate.getTime() - Date.now();
        if (diff <= 0) {
            goLive();
            return;
        }
        const d = Math.floor(diff / 86400000);
        const h = Math.floor((diff % 86400000) / 3600000);
        const m = Math.floor((diff % 3600000) / 60000);
        if (countdownEl) countdownEl.textContent = `${d}d ${String(h).padStart(2,'0')}h ${String(m).padStart(2,'0')}m`;
    }

    updateCountdown();
    const timer = setInterval(() => {
        const diff = eventDate.getTime() - Date.now();
        if (diff <= 0) {
            clearInterval(timer);
            goLive();
        } else {
            updateCountdown();
        }
    }, 1000);
</script>
