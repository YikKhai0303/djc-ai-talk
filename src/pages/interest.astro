---
import '../styles/global.css';
---

<html lang="en">
<head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/logo/logo192.png" />
    <meta name="viewport" content="width=device-width" />
    <title>DJC AI Talk</title>
</head>
<body class="pt-14 bg-white">

    <!-- Navbar -->
    <nav class="fixed top-0 left-0 right-0 z-40 bg-[#EBEBEB] border-b border-gray-200">
        <div class="max-w-5xl mx-auto px-6 h-14 flex items-center justify-center">
            <span class="text-sm font-bold tracking-widest uppercase">DJC AI Talk</span>
        </div>
    </nav>

    <!-- Form Section -->
    <section class="py-12 px-6">
        <div class="max-w-2xl mx-auto">
            <iframe
                src="https://link.djcsystem.com/widget/form/mXQMdaJuTUipHKVjR6AZ"
                style="width:100%;height:564px;border:none;border-radius:3px"
                id="inline-mXQMdaJuTUipHKVjR6AZ"
                data-layout="{'id':'INLINE'}"
                data-trigger-type="alwaysShow"
                data-trigger-value=""
                data-activation-type="alwaysActivated"
                data-activation-value=""
                data-deactivation-type="neverDeactivate"
                data-deactivation-value=""
                data-form-name="26th March collect interest"
                data-height="564"
                data-layout-iframe-id="inline-mXQMdaJuTUipHKVjR6AZ"
                data-form-id="mXQMdaJuTUipHKVjR6AZ"
                title="26th March collect interest"
            ></iframe>
            <script src="https://link.djcsystem.com/js/form_embed.js"></script>
        </div>
    </section>

    <!-- Footer -->
    <footer class="bg-white border-t border-gray-100 py-10 px-6">
        <div class="max-w-5xl mx-auto flex flex-col items-center gap-4">
            <img src="/logo/DJCLogoGrey.png" alt="DJC AI" class="h-10" />
            <p class="text-sm text-gray-400">
                &copy; {new Date().getFullYear()} DJC AI Sdn Bhd. All rights reserved.
            </p>
        </div>
    </footer>

</body>
</html>
