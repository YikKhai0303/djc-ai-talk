---
import '../styles/global.css';
---

<html lang="en">
<head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/logo/logo192.png" />
    <meta name="viewport" content="width=device-width" />
    <title>DJC AI Course 2026</title>
</head>
<body class="pt-14 bg-white">

    <!-- Navbar: course-specific, title only -->
    <nav class="fixed top-0 left-0 right-0 z-40 bg-[#EBEBEB] border-b border-gray-200">
        <div class="max-w-5xl mx-auto px-6 h-14 flex items-center justify-center">
            <span class="text-sm font-bold tracking-widest uppercase">DJC AI Course 2026</span>
        </div>
    </nav>

    <!-- Hero + Course Details (fused) -->
    <section class="bg-white text-black py-12 lg:py-16 px-6">
        <div class="max-w-5xl mx-auto grid grid-cols-1 lg:grid-cols-[2fr_3fr] gap-y-10 lg:gap-x-16 items-stretch">

            <!-- Left Column: Image -->
            <div class="rounded-2xl overflow-hidden bg-[#EBEBEB] w-full max-w-sm mx-auto lg:max-w-none lg:mx-0 aspect-square lg:aspect-auto">
                <img src="/images/djc_ai_course_book.png" alt="DJC AI Course 2026" class="w-full h-full object-cover" />
            </div>

            <!-- Right Column: Title + Details -->
            <div class="flex flex-col">
                <div class="self-start border border-black text-sm font-bold tracking-widest px-4 py-1 mb-6 rounded">
                    COURSE DETAILS
                </div>
                <h1 class="text-3xl lg:text-4xl font-bold leading-snug mb-4">
                    DJC AI Course 2026
                </h1>
                <p class="text-base text-gray-600 max-w-2xl mb-8">
                    A practical 3&#8209;day AI course designed to help participants apply AI in content creation and business operations.
                </p>

                <div class="flex flex-col gap-3 text-sm text-gray-700">

                    <div class="flex items-center gap-3">
                        <svg class="w-5 h-5 shrink-0" viewBox="0 0 20 20" fill="none">
                            <rect x="3" y="2" width="14" height="11" rx="2" stroke="black" stroke-width="1.8"/>
                            <path d="M7 18l3-2 3 2v-5H7v5z" stroke="black" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                            <path d="M7 6h6M7 9h4" stroke="black" stroke-width="1.5" stroke-linecap="round"/>
                        </svg>
                        <span class="w-[4.5rem] font-semibold shrink-0">Duration</span>
                        <span class="shrink-0">:</span>
                        <span>3-day course + 4 guided coaching sessions</span>
                    </div>

                    <div class="flex items-center gap-3">
                        <svg class="w-5 h-5 shrink-0" viewBox="0 0 20 20" fill="none">
                            <rect x="2" y="4" width="16" height="14" rx="2" stroke="black" stroke-width="1.8"/>
                            <path d="M2 8h16" stroke="black" stroke-width="1.8"/>
                            <path d="M6 2v4M14 2v4" stroke="black" stroke-width="1.8" stroke-linecap="round"/>
                        </svg>
                        <span class="w-[4.5rem] font-semibold shrink-0">Date</span>
                        <span class="shrink-0">:</span>
                        <span>May 2026 (exact dates to be announced)</span>
                    </div>

                    <div class="flex items-center gap-3">
                        <svg class="w-5 h-5 shrink-0" viewBox="0 0 20 20" fill="none">
                            <rect x="2" y="3" width="16" height="11" rx="2" stroke="black" stroke-width="1.8"/>
                            <path d="M7 17h6" stroke="black" stroke-width="1.8" stroke-linecap="round"/>
                            <path d="M10 14v3" stroke="black" stroke-width="1.8" stroke-linecap="round"/>
                        </svg>
                        <span class="w-[4.5rem] font-semibold shrink-0">Platform</span>
                        <span class="shrink-0">:</span>
                        <span>Zoom</span>
                    </div>

                    <div class="flex items-center gap-3">
                        <svg class="w-5 h-5 shrink-0" viewBox="0 0 20 20" fill="none">
                            <circle cx="10" cy="10" r="8" stroke="black" stroke-width="1.8"/>
                            <path d="M10 2c-2 2.5-3 5-3 8s1 5.5 3 8" stroke="black" stroke-width="1.5" stroke-linecap="round"/>
                            <path d="M10 2c2 2.5 3 5 3 8s-1 5.5-3 8" stroke="black" stroke-width="1.5" stroke-linecap="round"/>
                            <path d="M2 10h16" stroke="black" stroke-width="1.5" stroke-linecap="round"/>
                            <path d="M3 6.5h14M3 13.5h14" stroke="black" stroke-width="1.3" stroke-linecap="round"/>
                        </svg>
                        <span class="w-[4.5rem] font-semibold shrink-0">Language</span>
                        <span class="shrink-0">:</span>
                        <span>English</span>
                    </div>

                </div>

                <a href="#enroll" class="self-start mt-8 bg-black text-white text-sm font-semibold px-6 py-3 rounded hover:bg-gray-800 transition-colors duration-200">
                    Enroll Now
                </a>
            </div>

            <!-- Course Highlights: full width below both columns -->
            <div class="lg:col-span-2 border-t border-gray-100 pt-8">
                <p class="text-xs font-bold tracking-widest text-gray-400 uppercase mb-4">Course Highlights</p>
                <ul class="grid grid-cols-1 lg:grid-cols-2 gap-x-8 gap-y-3">
                    <li class="flex items-start gap-2">
                        <svg class="w-4 h-4 shrink-0 mt-0.5" viewBox="0 0 16 16" fill="none">
                            <circle cx="8" cy="8" r="7" stroke="black" stroke-width="1.5"/>
                            <path d="M5 8l2 2 4-4" stroke="black" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                        <span class="text-sm font-semibold text-gray-700">AI for Content Creation and Business Operations</span>
                    </li>
                    <li class="flex items-start gap-2">
                        <svg class="w-4 h-4 shrink-0 mt-0.5" viewBox="0 0 16 16" fill="none">
                            <circle cx="8" cy="8" r="7" stroke="black" stroke-width="1.5"/>
                            <path d="M5 8l2 2 4-4" stroke="black" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                        <span class="text-sm font-semibold text-gray-700">12-Month AI Auto Reply Chatbot Subscription</span>
                    </li>
                    <li class="flex items-start gap-2">
                        <svg class="w-4 h-4 shrink-0 mt-0.5" viewBox="0 0 16 16" fill="none">
                            <circle cx="8" cy="8" r="7" stroke="black" stroke-width="1.5"/>
                            <path d="M5 8l2 2 4-4" stroke="black" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                        <span class="text-sm font-semibold text-gray-700">Post Course Coaching Program Included</span>
                    </li>
                    <li class="flex items-start gap-2">
                        <svg class="w-4 h-4 shrink-0 mt-0.5" viewBox="0 0 16 16" fill="none">
                            <circle cx="8" cy="8" r="7" stroke="black" stroke-width="1.5"/>
                            <path d="M5 8l2 2 4-4" stroke="black" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                        <span class="text-sm font-semibold text-gray-700">Step by Step Implementation Support</span>
                    </li>
                    <li class="flex items-start gap-2">
                        <svg class="w-4 h-4 shrink-0 mt-0.5" viewBox="0 0 16 16" fill="none">
                            <circle cx="8" cy="8" r="7" stroke="black" stroke-width="1.5"/>
                            <path d="M5 8l2 2 4-4" stroke="black" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                        <span class="text-sm font-semibold text-gray-700">Community Support Group Access</span>
                    </li>
                    <li class="flex items-start gap-2">
                        <svg class="w-4 h-4 shrink-0 mt-0.5" viewBox="0 0 16 16" fill="none">
                            <circle cx="8" cy="8" r="7" stroke="black" stroke-width="1.5"/>
                            <path d="M5 8l2 2 4-4" stroke="black" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                        <span class="text-sm font-semibold text-gray-700">Session Recordings Included</span>
                    </li>
                </ul>
            </div>

        </div>
    </section>

    <!-- What You Get: 3 Cards -->
    <section class="bg-[#EBEBEB] py-16 lg:py-20 px-6">
        <div class="max-w-5xl mx-auto">

            <div class="text-center mb-12">
                <div class="inline-block border border-black text-sm font-bold tracking-widest px-4 py-1 mb-6 rounded">
                    WHAT YOU GET
                </div>
                <h2 class="text-2xl lg:text-3xl font-bold leading-snug mb-4">
                    What Is Included in This Course
                </h2>
                <p class="text-base text-gray-600 max-w-2xl mx-auto">
                    From core learning to continued support, here is what you will receive.
                </p>
            </div>

            <div class="grid grid-cols-1 lg:grid-cols-3 gap-5 items-stretch">

                <!-- Card 1: Core Learning Areas — white bg -->
                <div class="bg-white rounded-xl p-8 shadow-sm">
                    <div class="mb-4 text-center">
                        <svg class="w-7 h-7 mx-auto" viewBox="0 0 24 24" fill="none">
                            <rect x="8" y="2" width="8" height="4" rx="1" stroke="black" stroke-width="1.5"/>
                            <path d="M16 3h2a2 2 0 012 2v14a2 2 0 01-2 2H6a2 2 0 01-2-2V5a2 2 0 012-2h2" stroke="black" stroke-width="1.5" stroke-linecap="round"/>
                            <path d="M9 12l2 2 4-4" stroke="black" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                    </div>
                    <h3 class="text-base font-bold mb-2 text-center">Core Learning Areas</h3>
                    <p class="text-sm text-gray-500 mb-3 text-center">Using AI for content and business tasks</p>
                    <ol class="flex flex-col divide-y divide-gray-100">
                        <li class="flex items-center gap-4 py-3 text-sm text-gray-700">
                            <span class="text-xs font-bold text-gray-300 w-5 shrink-0">01</span>
                            Studio Quality Photo Generation
                        </li>
                        <li class="flex items-center gap-4 py-3 text-sm text-gray-700">
                            <span class="text-xs font-bold text-gray-300 w-5 shrink-0">02</span>
                            Interior Design Animation Creation
                        </li>
                        <li class="flex items-center gap-4 py-3 text-sm text-gray-700">
                            <span class="text-xs font-bold text-gray-300 w-5 shrink-0">03</span>
                            Marketing Video Production
                        </li>
                        <li class="flex items-center gap-4 py-3 text-sm text-gray-700">
                            <span class="text-xs font-bold text-gray-300 w-5 shrink-0">04</span>
                            Company Theme Music Creation
                        </li>
                        <li class="flex items-center gap-4 py-3 text-sm text-gray-700">
                            <span class="text-xs font-bold text-gray-300 w-5 shrink-0">05</span>
                            Agreement and Document Writing
                        </li>
                    </ol>
                </div>

                <!-- Card 2: Included Benefits — white bg -->
                <div class="bg-white rounded-xl p-8 shadow-sm flex flex-col">
                    <div class="mb-4 text-center">
                        <svg class="w-7 h-7 mx-auto" viewBox="0 0 24 24" fill="none">
                            <path d="M20 12V22H4V12" stroke="black" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                            <path d="M22 7H2v5h20V7z" stroke="black" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                            <path d="M12 22V7" stroke="black" stroke-width="1.5" stroke-linecap="round"/>
                            <path d="M12 7H7.5a2.5 2.5 0 010-5C11 2 12 7 12 7z" stroke="black" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                            <path d="M12 7h4.5a2.5 2.5 0 000-5C13 2 12 7 12 7z" stroke="black" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                    </div>
                    <h3 class="text-base font-bold mb-1 text-center">Included Benefits</h3>
                    <p class="text-sm text-gray-500 mb-3 text-center">Added value with your course</p>
                    <ul class="flex flex-col divide-y divide-gray-100 flex-1">
                        <li class="flex items-center gap-4 py-3 text-sm text-gray-700">
                            <svg class="w-5 h-5 shrink-0" viewBox="0 0 20 20" fill="none">
                                <path d="M10 2l1.5 4.5H16l-3.5 2.5 1.5 4.5L10 11l-4 2.5 1.5-4.5L4 6.5h4.5L10 2z" stroke="#d1d5db" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
                            </svg>
                            12 Months of AI Auto Reply Chatbot Subscription
                        </li>
                        <li class="flex items-center gap-4 py-3 text-sm text-gray-700">
                            <svg class="w-5 h-5 shrink-0" viewBox="0 0 20 20" fill="none">
                                <path d="M10 2l1.5 4.5H16l-3.5 2.5 1.5 4.5L10 11l-4 2.5 1.5-4.5L4 6.5h4.5L10 2z" stroke="#d1d5db" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
                            </svg>
                            Community Support Group Access
                        </li>
                        <li class="flex items-center gap-4 py-3 text-sm text-gray-700">
                            <svg class="w-5 h-5 shrink-0" viewBox="0 0 20 20" fill="none">
                                <path d="M10 2l1.5 4.5H16l-3.5 2.5 1.5 4.5L10 11l-4 2.5 1.5-4.5L4 6.5h4.5L10 2z" stroke="#d1d5db" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
                            </svg>
                            Session Recordings Included
                        </li>
                    </ul>
                </div>

                <!-- Card 3: Post Course Coaching -->
                <div class="bg-white rounded-xl p-8 shadow-sm flex flex-col">
                    <div class="mb-4 text-center">
                        <svg class="w-7 h-7 mx-auto" viewBox="0 0 24 24" fill="none">
                            <path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2" stroke="black" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                            <circle cx="9" cy="7" r="4" stroke="black" stroke-width="1.5"/>
                            <path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75" stroke="black" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                    </div>
                    <h3 class="text-base font-bold mb-2 text-center">Post Course Coaching Program</h3>
                    <p class="text-sm text-gray-500 mb-3 text-center">Continued support after the course</p>
                    <ul class="flex flex-col divide-y divide-gray-100 flex-1">
                        <li class="flex items-center gap-4 py-3 text-sm text-gray-700">
                            <svg class="w-4 h-4 shrink-0 text-gray-300" viewBox="0 0 16 16" fill="none">
                                <path d="M2 8h12M8 3l5 5-5 5" stroke="#d1d5db" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                            </svg>
                            Step-by-step guidance to implement what you learned
                        </li>
                        <li class="flex items-center gap-4 py-3 text-sm text-gray-700">
                            <svg class="w-4 h-4 shrink-0 text-gray-300" viewBox="0 0 16 16" fill="none">
                                <path d="M2 8h12M8 3l5 5-5 5" stroke="#d1d5db" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                            </svg>
                            4 weeks, 1 session per week
                        </li>
                        <li class="flex items-center gap-4 py-3 text-sm text-gray-700">
                            <svg class="w-4 h-4 shrink-0 text-gray-300" viewBox="0 0 16 16" fill="none">
                                <path d="M2 8h12M8 3l5 5-5 5" stroke="#d1d5db" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                            </svg>
                            2 hours per session via Zoom
                        </li>
                    </ul>
                </div>

            </div>
        </div>
    </section>

    <!-- Payment Section (GHL embed placeholder) -->
    <section id="enroll" class="bg-white py-16 lg:py-20 px-6">
        <div class="max-w-5xl mx-auto">
            <div class="text-center mb-10">
                <div class="inline-block border border-black text-sm font-bold tracking-widest px-4 py-1 mb-6 rounded">
                    ENROLL NOW
                </div>
                <h2 class="text-2xl lg:text-3xl font-bold leading-snug mb-4">
                    Secure Your Spot
                </h2>
                <p class="text-base text-gray-600 max-w-xl mx-auto">
                    Join the DJC AI Course 2026.<br />Start Applying AI to Content Creation and Business Operations.
                </p>
            </div>
            <div class="max-w-2xl mx-auto">
                <iframe
                    src="https://link.djcsystem.com/widget/form/Zb3lOMaWFbuzCRrHb8Df"
                    style="width:100%;height:1164px;border:none;border-radius:3px"
                    id="inline-Zb3lOMaWFbuzCRrHb8Df"
                    data-layout="{'id':'INLINE'}"
                    data-trigger-type="alwaysShow"
                    data-trigger-value=""
                    data-activation-type="alwaysActivated"
                    data-activation-value=""
                    data-deactivation-type="neverDeactivate"
                    data-deactivation-value=""
                    data-form-name="DJC AI Course 2026"
                    data-height="1164"
                    data-layout-iframe-id="inline-Zb3lOMaWFbuzCRrHb8Df"
                    data-form-id="Zb3lOMaWFbuzCRrHb8Df"
                    title="DJC AI Course 2026"
                ></iframe>
                <script src="https://link.djcsystem.com/js/form_embed.js"></script>
            </div>
        </div>
    </section>

    <!-- Footer -->
    <footer class="bg-white border-t border-gray-100 py-10 px-6">
        <div class="max-w-5xl mx-auto flex flex-col items-center gap-4">
            <img src="/logo/DJCLogoGrey.png" alt="DJC AI" class="h-10" />
            <p class="text-sm text-gray-400">
                &copy; {new Date().getFullYear()} DJC AI Sdn Bhd. All rights reserved.
            </p>
        </div>
    </footer>

</body>
</html>

<style>
    .diagonal-stripes {
        background-image: linear-gradient(#e5e7eb 1px, transparent 1px), linear-gradient(90deg, #e5e7eb 1px, transparent 1px);
        background-size: 36px 36px;
        -webkit-mask-image: radial-gradient(ellipse at 0% 100%, black 0%, transparent 45%),
                            radial-gradient(ellipse at 100% 0%, black 0%, transparent 45%);
        mask-image: radial-gradient(ellipse at 0% 100%, black 0%, transparent 45%),
                    radial-gradient(ellipse at 100% 0%, black 0%, transparent 45%);
        -webkit-mask-composite: source-over;
        mask-composite: add;
    }
</style>
